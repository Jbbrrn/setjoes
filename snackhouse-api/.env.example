## Copy to `.env` and fill in real values.
## Do not commit `.env` to source control.

# --- Database (MySQL) ---
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=setjoesdb
DB_PORT=3306

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Optional: POS frontend config (Create React App) ---
# If you also run the POS app from this same environment file (not typical),
# this is the API base URL the frontend uses.
REACT_APP_API_URL=http://localhost:3001/api
